#!/bin/sh
msg_file="$1"
first_line=$(head -n 1 "$msg_file")
case "$first_line" in
  "[feat]"*|"[fix]"*|"[chore]"*|"[docs]"*|"[refactor]"*|"[test]"*)
    exit 0
    ;;
  *)
    echo "❌ Commit message must start with one of: [feat] [fix] [chore] [docs] [refactor] [test]" >&2
    echo "   got: $first_line" >&2
    exit 1
    ;;
esac
